---
import { primaryNav } from "../data/docs";

const pathname = Astro.url.pathname;
---

<header class="site-header">
  <div class="shell site-header__inner">
    <a class="brand" href="/">
      <span class="brand__eyebrow">Gooselake</span>
      <span class="brand__title">Agent runtime control tower</span>
    </a>
    <nav class="site-nav" aria-label="Primary">
      {primaryNav.map((item) => {
        const active = !item.external && pathname === item.href;
        return (
          <a
            class:list={["site-nav__link", active && "is-active"]}
            href={item.href}
            target={item.external ? "_blank" : undefined}
            rel={item.external ? "noreferrer" : undefined}
          >
            {item.label}
          </a>
        );
      })}
    </nav>
  </div>
</header>
