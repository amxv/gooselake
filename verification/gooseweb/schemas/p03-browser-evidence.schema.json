{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gooseweb://schemas/p03-browser-evidence/v1",
  "title": "P03 headless real-Chromium evidence descriptor v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_revision", "phase_id", "attempt", "candidate_head_sha", "served_head_sha",
    "candidate_tree_sha", "served_tree_sha", "browser", "supervisor_attachment",
    "journey", "authority_chain", "first_divergent_layer", "captures", "viewports", "reconstruction", "fixture_leakage",
    "redaction", "completion"
  ],
  "properties": {
    "schema_revision": { "const": "gooseweb-p03-browser-evidence/v1" },
    "phase_id": { "const": "P03" },
    "attempt": { "type": "integer", "minimum": 1 },
    "candidate_head_sha": { "$ref": "#/$defs/sha" },
    "served_head_sha": { "$ref": "#/$defs/sha" },
    "candidate_tree_sha": { "$ref": "#/$defs/sha" },
    "served_tree_sha": { "$ref": "#/$defs/sha" },
    "browser": {
      "type": "object", "additionalProperties": false,
      "required": ["mechanism", "session_name", "globally_unique", "engine", "execution_mode", "headed_cli_value", "headed_environment", "headed_config", "binary_path", "version", "user_agent", "user_agent_reduction", "user_agent_data", "navigator_webdriver", "real_local_chromium", "profile_policy", "persistent_state_loaded"],
      "properties": {
        "mechanism": { "const": "agent-browser" },
        "session_name": { "type": "string", "pattern": "^gooseweb-p03-[a-f0-9]{7}-a[1-9][0-9]*-[a-z0-9][a-z0-9-]*-[a-f0-9]{8}$" },
        "globally_unique": { "const": true },
        "engine": { "const": "chrome" },
        "execution_mode": { "const": "headless" },
        "headed_cli_value": { "const": false },
        "headed_environment": { "const": "absent" },
        "headed_config": { "const": "absent" },
        "binary_path": { "type": "string", "pattern": "(?:Google Chrome|Chromium)(?:\\.app)?/" },
        "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "user_agent": { "type": "string", "pattern": "HeadlessChrome/[0-9]+\\.0\\.0\\.0" },
        "user_agent_reduction": {
          "type": "object", "additionalProperties": false,
          "required": ["mode", "token_version"],
          "properties": {
            "mode": { "const": "reduced_major_only" },
            "token_version": { "type": "string", "pattern": "^[0-9]+\\.0\\.0\\.0$" }
          }
        },
        "user_agent_data": {
          "type": "object", "additionalProperties": false,
          "required": ["availability", "full_version_list", "unavailable_reason"],
          "properties": {
            "availability": { "enum": ["available", "unavailable"] },
            "full_version_list": {
              "type": "array",
              "items": {
                "type": "object", "additionalProperties": false,
                "required": ["brand", "version"],
                "properties": {
                  "brand": { "type": "string", "minLength": 1 },
                  "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+$" }
                }
              }
            },
            "unavailable_reason": { "type": "string" }
          }
        },
        "navigator_webdriver": { "const": true },
        "real_local_chromium": { "const": true },
        "profile_policy": { "const": "fresh_ephemeral" },
        "persistent_state_loaded": { "const": false }
      }
    },
    "supervisor_attachment": {
      "type": "object", "additionalProperties": false,
      "required": ["url_source", "stack_started_by", "reviewer_started_stack", "lease_exclusive", "lease_id", "lease_sequence", "supervisor_identity", "stack_configuration_sha256", "clean_tree", "hot_reload"],
      "properties": {
        "url_source": { "const": "supervisor_provided" },
        "stack_started_by": { "const": "supervisor" },
        "reviewer_started_stack": { "const": false },
        "lease_exclusive": { "const": true },
        "lease_id": { "type": "string", "pattern": "^gooseweb-migration-[0-9]{6,}$" },
        "lease_sequence": { "type": "integer", "minimum": 1 },
        "supervisor_identity": { "type": "string", "minLength": 1 },
        "stack_configuration_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "clean_tree": { "const": true },
        "hot_reload": { "const": false }
      }
    },
    "journey": {
      "type": "object", "additionalProperties": false,
      "required": ["selected_roster_control", "action"],
      "properties": {
        "selected_roster_control": {
          "type": "object", "additionalProperties": false,
          "required": ["role", "accessible_name", "visible", "enabled", "selected"],
          "properties": {
            "role": { "const": "button" }, "accessible_name": { "type": "string", "minLength": 1 },
            "visible": { "const": true }, "enabled": { "const": true }, "selected": { "const": true }
          }
        },
        "action": {
          "type": "object", "additionalProperties": false,
          "required": ["manifest_action_id", "control", "submit", "command", "submitted_text", "browser_submission_count", "command_count", "visible_submission_count"],
          "properties": {
            "manifest_action_id": { "type": "string", "minLength": 1 },
            "control": { "$ref": "#/$defs/semanticControl" }, "submit": { "$ref": "#/$defs/semanticControl" },
            "command": { "type": "string", "minLength": 1 }, "submitted_text": { "type": "string", "minLength": 1 },
            "browser_submission_count": { "const": 1 }, "command_count": { "const": 1 }, "visible_submission_count": { "const": 1 }
          }
        }
      }
    },
    "authority_chain": {
      "type": "array", "minItems": 4, "maxItems": 4,
      "prefixItems": [
        { "$ref": "#/$defs/runtimeAuthority" }, { "$ref": "#/$defs/towerAuthority" },
        { "$ref": "#/$defs/storeAuthority" }, { "$ref": "#/$defs/reactAuthority" }
      ],
      "items": false
    },
    "first_divergent_layer": {
      "oneOf": [{ "type": "null" }, { "enum": ["Gooselake", "Goosetower", "Gooseweb Worker/store", "Gooseweb React"] }]
    },
    "captures": {
      "type": "object", "additionalProperties": false,
      "required": ["console", "network", "websocket"],
      "properties": {
        "console": { "$ref": "#/$defs/capture" },
        "network": { "$ref": "#/$defs/capture" },
        "websocket": { "$ref": "#/$defs/capture" }
      }
    },
    "viewports": {
      "type": "array", "minItems": 3, "maxItems": 3,
      "prefixItems": [
        { "$ref": "#/$defs/desktop" }, { "$ref": "#/$defs/tablet" }, { "$ref": "#/$defs/phone" }
      ],
      "items": false
    },
    "reconstruction": {
      "type": "object", "additionalProperties": false,
      "required": ["ordinary_reload", "hard_reload", "navigation_away_back", "websocket_reconnect", "fresh_context", "old_context_disposed", "indexeddb_cleared", "cookies_cleared", "local_storage_cleared", "session_storage_cleared", "cache_storage_cleared", "service_workers_unregistered", "remaining_cache_names", "remaining_service_workers", "initial_prior_context_nonce", "old_context_nonce", "fresh_context_prior_nonce", "fresh_context_nonce", "stale_context_detected"],
      "properties": {
        "ordinary_reload": { "$ref": "#/$defs/reconstructionResult" }, "hard_reload": { "$ref": "#/$defs/reconstructionResult" },
        "navigation_away_back": { "$ref": "#/$defs/reconstructionResult" }, "websocket_reconnect": { "$ref": "#/$defs/reconstructionResult" },
        "fresh_context": { "$ref": "#/$defs/reconstructionResult" }, "old_context_disposed": { "const": true },
        "indexeddb_cleared": { "const": true }, "cookies_cleared": { "const": true },
        "local_storage_cleared": { "const": true }, "session_storage_cleared": { "const": true },
        "cache_storage_cleared": { "const": true }, "service_workers_unregistered": { "const": true },
        "remaining_cache_names": { "const": 0 }, "remaining_service_workers": { "const": 0 },
        "initial_prior_context_nonce": { "type": "null" },
        "old_context_nonce": { "type": "string", "minLength": 8 },
        "fresh_context_prior_nonce": { "type": "null" },
        "fresh_context_nonce": { "type": "string", "minLength": 8 },
        "stale_context_detected": { "const": false }
      }
    },
    "fixture_leakage": {
      "type": "object", "additionalProperties": false,
      "required": ["default_development", "production_build", "query_flags_present", "fixture_markers_found"],
      "properties": {
        "default_development": { "const": "pass" }, "production_build": { "const": "pass" },
        "query_flags_present": { "const": false }, "fixture_markers_found": { "const": 0 }
      }
    },
    "redaction": {
      "type": "object", "additionalProperties": false,
      "required": ["at_capture", "query_values_retained", "credentials_retained", "cookies_retained", "csrf_retained", "tickets_retained", "raw_image_bytes_retained", "secret_config_retained"],
      "properties": {
        "at_capture": { "const": true }, "query_values_retained": { "const": false },
        "credentials_retained": { "const": false }, "cookies_retained": { "const": false },
        "csrf_retained": { "const": false }, "tickets_retained": { "const": false },
        "raw_image_bytes_retained": { "const": false }, "secret_config_retained": { "const": false }
      }
    },
    "completion": {
      "type": "object", "additionalProperties": false,
      "required": ["product_approved", "known_defects", "baseline_detected_count", "procedure_overhead_recorded", "alternate_browser_framework_used", "browser_runner_committed"],
      "properties": {
        "product_approved": { "const": false }, "known_defects": { "type": "array", "maxItems": 0 },
        "baseline_detected_count": { "const": 10 }, "procedure_overhead_recorded": { "const": true },
        "alternate_browser_framework_used": { "const": false }, "browser_runner_committed": { "const": false }
      }
    }
  },
  "$defs": {
    "sha": { "type": "string", "pattern": "^[a-f0-9]{40}$" },
    "capture": {
      "type": "object", "additionalProperties": false,
      "required": ["complete", "unexpected_failures", "redacted_at_capture"],
      "properties": { "complete": { "const": true }, "unexpected_failures": { "const": 0 }, "redacted_at_capture": { "const": true } }
    },
    "semanticControl": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "accessible_name", "visible", "enabled"],
      "properties": {
        "role": { "type": "string", "minLength": 1 }, "accessible_name": { "type": "string", "minLength": 1 },
        "visible": { "const": true }, "enabled": { "const": true }
      }
    },
    "authorityBase": {
      "type": "object", "additionalProperties": false,
      "required": ["layer", "status", "artifact", "correlation_id", "semantic_identity", "cursor_or_version", "content_sha256", "observed_instances", "missing_count", "duplicate_count", "order_errors", "baseline_defect_id"],
      "properties": {
        "layer": { "type": "string" }, "status": { "enum": ["observed", "baseline_divergent"] },
        "artifact": { "type": "string", "minLength": 1 },
        "correlation_id": { "type": "string", "minLength": 1 }, "semantic_identity": { "type": "string", "minLength": 1 },
        "cursor_or_version": { "type": "string", "minLength": 1 }, "content_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "observed_instances": { "type": "integer", "minimum": 0 },
        "missing_count": { "type": "integer", "minimum": 0 }, "duplicate_count": { "type": "integer", "minimum": 0 },
        "order_errors": { "type": "integer", "minimum": 0 },
        "baseline_defect_id": { "oneOf": [{ "type": "null" }, { "type": "string", "pattern": "^BASE-[A-Z0-9-]+$" }] }
      }
    },
    "runtimeAuthority": { "allOf": [{ "$ref": "#/$defs/authorityBase" }, { "properties": { "layer": { "const": "Gooselake" }, "artifact": { "const": "runtime-state.redacted.json" } } }] },
    "towerAuthority": { "allOf": [{ "$ref": "#/$defs/authorityBase" }, { "properties": { "layer": { "const": "Goosetower" }, "artifact": { "const": "tower-state.redacted.json" } } }] },
    "storeAuthority": { "allOf": [{ "$ref": "#/$defs/authorityBase" }, { "properties": { "layer": { "const": "Gooseweb Worker/store" }, "artifact": { "const": "store-state.redacted.json" } } }] },
    "reactAuthority": { "allOf": [{ "$ref": "#/$defs/authorityBase" }, { "properties": { "layer": { "const": "Gooseweb React" }, "artifact": { "enum": ["screenshots/1440x1000.png", "screenshots/820x1000.png", "screenshots/520x900.png"] } } }] },
    "reconstructionResult": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "artifact", "missing_count", "duplicate_count", "order_errors", "baseline_defect_id"],
      "properties": {
        "status": { "enum": ["pass", "baseline_divergent"] }, "artifact": { "type": "string", "minLength": 1 },
        "missing_count": { "type": "integer", "minimum": 0 }, "duplicate_count": { "type": "integer", "minimum": 0 },
        "order_errors": { "type": "integer", "minimum": 0 },
        "baseline_defect_id": { "oneOf": [{ "type": "null" }, { "type": "string", "pattern": "^BASE-[A-Z0-9-]+$" }] }
      }
    },
    "viewportBase": {
      "type": "object", "additionalProperties": false,
      "required": ["id", "width", "height", "screenshot", "screenshot_path", "horizontal_overflow", "composer_inside_viewport", "primary_action_inside_viewport", "critical_actions_reachable"],
      "properties": {
        "id": { "type": "string" }, "width": { "type": "integer" }, "height": { "type": "integer" },
        "screenshot": { "const": true }, "screenshot_path": { "type": "string", "minLength": 1 },
        "horizontal_overflow": { "const": false }, "composer_inside_viewport": { "const": true },
        "primary_action_inside_viewport": { "const": true }, "critical_actions_reachable": { "const": true }
      }
    },
    "desktop": { "allOf": [{ "$ref": "#/$defs/viewportBase" }, { "properties": { "id": { "const": "1440x1000" }, "width": { "const": 1440 }, "height": { "const": 1000 } } }] },
    "tablet": { "allOf": [{ "$ref": "#/$defs/viewportBase" }, { "properties": { "id": { "const": "820x1000" }, "width": { "const": 820 }, "height": { "const": 1000 } } }] },
    "phone": { "allOf": [{ "$ref": "#/$defs/viewportBase" }, { "properties": { "id": { "const": "520x900" }, "width": { "const": 520 }, "height": { "const": 900 } } }] }
  }
}
