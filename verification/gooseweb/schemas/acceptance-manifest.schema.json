              "type": "string",
              "minLength": 1
            }
          }
        },
        "compatibility": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason"
          ],
          "properties": {
            "status": {
              "enum": [
                "not_applicable",
                "observed_only",
                "no_change",
                "reference_only"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "rollback": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason"
          ],
          "properties": {
            "status": {
              "enum": [
                "not_applicable",
                "observed_only",
                "no_change",
                "reference_only"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "performance": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason"
          ],
          "properties": {
            "status": {
              "enum": [
                "not_applicable",
                "observed_only",
                "no_change",
                "reference_only"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "security": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason"
          ],
          "properties": {
            "status": {
              "enum": [
                "not_applicable",
                "observed_only",
                "no_change",
                "reference_only"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "data_retention_gc": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason"
          ],
          "properties": {
            "status": {
              "enum": [
                "not_applicable",
                "observed_only",
                "no_change",
                "reference_only"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "deployment": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "reason"
          ],
          "properties": {
            "status": {
              "enum": [
                "not_applicable",
                "observed_only",
                "no_change",
                "reference_only"
              ]
            },
            "reason": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "provenance_reuse": {
          "type": "object",
