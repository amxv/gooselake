{
  "schema_revision": "gooseweb-network-allowlist/v4",
  "capture_boundary": {
    "source": "unfiltered agent-browser network requests including successes",
    "raw_capture_retained": true,
    "query_values_retained": false,
    "query_keys_retained": true,
    "ignored_same_origin_success_resource_types": [
      "stylesheet",
      "font",
      "script",
      "module"
    ],
    "ignored_status_min": 200,
    "ignored_status_max": 399,
    "failure_filtering_prohibited": true,
    "unclassified_filtering_prohibited": true
  },
  "permitted_exact_evaluated_http_variants": [
    {
      "variant_id": "base-without-favicon-request",
      "requests": [
        {
          "method": "GET",
          "path": "/",
          "status": 200,
          "resource_type": "document",
          "baseline_defect_id": ""
        },
        {
          "method": "POST",
          "path": "/api/dev-ticket",
          "status": 200,
          "resource_type": "api",
          "baseline_defect_id": ""
        }
      ]
    },
    {
      "variant_id": "base-with-favicon-not-found",
      "requests": [
        {
          "method": "GET",
          "path": "/",
          "status": 200,
          "resource_type": "document",
          "baseline_defect_id": ""
        },
        {
          "method": "POST",
          "path": "/api/dev-ticket",
          "status": 200,
          "resource_type": "api",
          "baseline_defect_id": ""
        },
        {
          "method": "GET",
          "path": "/favicon.ico",
          "status": 404,
          "resource_type": "other",
          "baseline_defect_id": "BASE-P01-FAVICON-NOT-FOUND"
        }
      ]
    }
  ],
  "exact_websocket_events": [
    {
      "event": "open",
      "code": 0
    }
  ],
  "policy": "The raw request list is retained. The validator itself ignores only 2xx/3xx same-origin stylesheet, font, script, and module resources by exact resource type; it cannot ignore any 4xx/5xx, cross-origin, API, document, WebSocket, or unclassified request. The resulting evaluated multiset must exactly equal either base document plus dev-ticket traffic, or that base plus the retained favicon 404 with its exact baseline mapping. Favicon absence never fabricates a request."
}
