[Unit]
Description=GG Runtime (user service)
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=10

[Service]
Type=simple
WorkingDirectory=%h
Environment=RUST_LOG=info
EnvironmentFile=-%h/.config/gg-runtime/runtime.env
ExecStart=%h/.local/share/gg-runtime/current/bin/gg-runtime-server --config %h/.config/gg-runtime/runtime-server.toml
Restart=on-failure
RestartSec=2
TimeoutStopSec=45
KillMode=mixed
LimitNOFILE=65536
UMask=0077

[Install]
WantedBy=default.target
