{
  "schema_revision": "gooseweb-console-allowlist/v3",
  "capture_boundary": {
    "source": "unfiltered agent-browser console output",
    "filtering": "none",
    "normalization": "none",
    "warnings_errors_exceptions_always_fail": true
  },
  "exact_messages": [
    {
      "level": "debug",
      "message": "[vite] connecting..."
    },
    {
      "level": "debug",
      "message": "[vite] connected."
    }
  ],
  "policy": "The complete unfiltered agent-browser console multiset must match exactly. No message is hidden, normalized, regex-matched, or substring-suppressed."
}
