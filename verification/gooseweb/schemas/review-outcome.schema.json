{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gooseweb://schemas/review-outcome/v1",
  "title": "Gooseweb changes-required review outcome v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_revision",
    "phase_id",
    "base_sha",
    "reviewed_range",
    "attempt",
    "candidate_head_sha",
    "candidate_tree_sha",
    "manifest",
    "lease",
    "status",
    "clearance_issued",
    "product_approved",
    "recipient_role",
    "findings",
    "recorded_at"
  ],
  "properties": {
    "schema_revision": {
      "const": "gooseweb-review-outcome/v1"
    },
    "phase_id": {
      "type": "string",
      "pattern": "^P(0[1-9]|[1-4][0-9]|5[0-6])$"
    },
    "base_sha": {
      "const": "ca88bfe56719f69fe59151372e0d5aa76b2c92ab"
    },
    "reviewed_range": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}\\.\\.[a-f0-9]{40}$"
    },
    "attempt": {
      "type": "integer",
      "minimum": 1
    },
    "candidate_head_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "candidate_tree_sha": {
      "type": "string",
      "pattern": "^[a-f0-9]{40}$"
    },
    "manifest": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "revision",
        "sha256"
      ],
      "properties": {
        "path": {
          "const": "verification/gooseweb/manifests/p01-team-comms-live.json"
        },
        "revision": {
          "const": 2
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "lease": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lease_id",
        "sequence",
        "released_at"
      ],
      "properties": {
        "lease_id": {
          "type": "string",
          "pattern": "^gooseweb-migration-[0-9]{6,}$"
        },
        "sequence": {
          "type": "integer",
          "minimum": 1
        },
        "released_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "status": {
      "const": "changes_required"
    },
    "clearance_issued": {
      "const": false
    },
    "product_approved": {
      "const": false
    },
    "recipient_role": {
      "const": "none"
    },
    "findings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^P[0-9]{2}-BLOCK-[0-9]{3}$"
      }
    },
    "recorded_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
