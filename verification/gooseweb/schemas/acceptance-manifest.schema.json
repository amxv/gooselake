    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_repository",
        "source_commit",
        "references",
        "reuse_status",
        "destination_symbols",
        "native_tauri_assumptions_removed"
      ],
      "properties": {
        "source_repository": {
          "type": "string",
          "minLength": 1
        },
        "source_commit": {
          "type": "string",
          "pattern": "^[a-f0-9]{40}$"
        },
        "references": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "reuse_status": {
          "const": "reference_only"
        },
        "destination_symbols": {
          "type": "array",
          "maxItems": 0
        },
        "native_tauri_assumptions_removed": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
