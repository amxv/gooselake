{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "gooseweb://schemas/lifecycle-current/v1",
  "title": "Gooseweb canonical lifecycle tip pointer v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_revision",
    "current"
  ],
  "properties": {
    "schema_revision": {
      "const": "gooseweb-lifecycle-current/v1"
    },
    "current": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "attestation_id",
        "attestation_sequence",
        "path",
        "sha256"
      ],
      "properties": {
        "attestation_id": {
          "type": "string",
          "pattern": "^gooseweb-lifecycle-[0-9]{6,}$"
        },
        "attestation_sequence": {
          "type": "integer",
          "minimum": 1
        },
        "path": {
          "type": "string",
          "pattern": "^attestations/gooseweb-lifecycle-[0-9]{6}-[a-f0-9]{64}\\.json$"
        },
        "sha256": {
          "type": "string",
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    }
  }
}
